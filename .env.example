# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/journal_dev

# Day One SQLite path (required for pnpm sync)
# macOS default: ~/Library/Group Containers/5U8NS4GX82.dayoneapp2/Data/Documents/DayOne.sqlite
DAYONE_SQLITE_PATH=/path/to/DayOne.sqlite

# OpenAI (embeddings + optional chat provider)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5-mini

# Telegram chatbot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
# LLM provider for Telegram conversations: anthropic | openai
TELEGRAM_LLM_PROVIDER=anthropic
# Voice reply policy: off | adaptive | always
TELEGRAM_VOICE_REPLY_MODE=adaptive
# In adaptive mode, send voice for every Nth text-origin response
TELEGRAM_VOICE_REPLY_EVERY=3
TELEGRAM_VOICE_REPLY_MIN_CHARS=16
TELEGRAM_VOICE_REPLY_MAX_CHARS=450
TELEGRAM_SOUL_ENABLED=true
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cloudflare R2 (for media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=espejo-media
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Gmail SMTP (book mailer + HN distill emails)
# App password: https://myaccount.google.com/apppasswords (requires 2FA)
GMAIL_APP_PASSWORD=
GMAIL_FROM_EMAIL=mitchhankins01@gmail.com
# Destination for HN distillations + other notification emails.
# Defaults to GMAIL_FROM_EMAIL (send to self) when unset.
GMAIL_TO_EMAIL=

# Server
NODE_ENV=development
PORT=3000
